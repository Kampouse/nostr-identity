# OutLayer Configuration
OUTLAYER_PROJECT_ID=kampouse.near/nostr-identity-zkp-tee-v3
OUTLAYER_PAYMENT_KEY=your_account.near:1:your_payment_key_here

# OutLayer Secrets (for TEE to sign transactions)
OUTLAYER_SECRETS_PROFILE=default
OUTLAYER_SECRETS_ACCOUNT_ID=

# TEE Relayer Public Key (derived from TEE's private key)
# Run: node scripts/derive-tee-keypair.mjs ed25519:your_tee_private_key
NEXT_PUBLIC_TEE_PUBLIC_KEY=ed25519:TEES_PUBLIC_KEY_HERE

# NEAR RPC URL (used by TEE to submit transactions)
NEAR_RPC_URL=https://rpc.testnet.near.org

# NEAR Smart Contract ID
NEXT_PUBLIC_CONTRACT_ID=nostr-identity.kampouse.testnet

# Environment (testnet|mainnet)
NEXT_PUBLIC_NEAR_NETWORK=testnet
