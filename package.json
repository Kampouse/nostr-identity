{
  "name": "nostr-identity",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@8.15.0",
  "workspaces": [
    "apps/*",
    "services/*",
    "packages/*"
  ],
  "engines": {
    "node": ">=18.0.0",
    "pnpm": ">=8.0.0"
  },
  "scripts": {
    "postinstall": "pnpm build:packages",
    "dev": "pnpm --filter @nostr-identity/web dev",
    "build:wasm": "cd packages/zkp-wasm && wasm-pack build --target web --out-dir pkg",
    "build:packages": "pnpm build:wasm && pnpm --filter @nostr-identity/crypto build && pnpm --filter @nostr-identity/types build && pnpm --filter @nostr-identity/nostr build",
    "build": "pnpm build:packages && pnpm --filter @nostr-identity/web build",
    "build:contract": "cd contracts/nostr-identity-contract-zkp-tee && cargo build --target wasm32-wasip2 --release",
    "build:all": "pnpm build:contract && pnpm build",
    "start": "pnpm --filter @nostr-identity/web start",
    "lint": "pnpm --filter @nostr-identity/web lint",
    "clean": "./scripts/clean.sh",
    "vercel-build": "pnpm build"
  },
  "devDependencies": {
    "@types/node": "^20",
    "typescript": "^5"
  }
}
