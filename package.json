{
  "name": "nostr-identity",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@8.15.0",
  "workspaces": [
    "apps/*",
    "services/*",
    "packages/*"
  ],
  "engines": {
    "node": ">=18.0.0",
    "pnpm": ">=8.0.0"
  },
  "scripts": {
    "postinstall": "pnpm build:packages",
    "dev": "next dev",
    "build:wasm": "cd packages/zkp-wasm && wasm-pack build --target web --out-dir pkg",
    "build:packages": "pnpm --filter @nostr-identity/crypto build && pnpm --filter @nostr-identity/types build && pnpm --filter @nostr-identity/nostr build",
    "build": "pnpm build:packages && next build",
    "build:contract": "cd contracts/nostr-identity-contract-zkp-tee && cargo build --target wasm32-wasip2 --release",
    "build:all": "pnpm build:contract && pnpm build",
    "start": "next start",
    "lint": "next lint",
    "clean": "./scripts/clean.sh",
    "vercel-build": "pnpm build",
    "cf:build": "pnpm build:packages && opennextjs-cloudflare build",
    "cf:dev": "wrangler dev",
    "cf:preview": "wrangler dev",
    "cf:deploy": "wrangler deploy"
  },
  "dependencies": {
    "@hot-labs/near-connect": "^0.11.1",
    "@noble/secp256k1": "^2.1.0",
    "@nostr-identity/crypto": "workspace:*",
    "@nostr-identity/nostr": "workspace:*",
    "@nostr-identity/types": "workspace:*",
    "@nostr-identity/zkp-wasm": "workspace:*",
    "@scure/base": "^1.1.0",
    "bs58": "^6.0.0",
    "near-api-js": "^7.2.0",
    "next": "15",
    "react": "19",
    "react-dom": "19"
  },
  "devDependencies": {
    "@opennextjs/cloudflare": "^1.18.0",
    "@tailwindcss/postcss": "^4.2.2",
    "@types/node": "^20",
    "@types/react": "19",
    "@types/react-dom": "19",
    "autoprefixer": "^10.4.27",
    "tailwindcss": "^4.2.2",
    "typescript": "^5",
    "wrangler": "^4.78.0"
  }
}
