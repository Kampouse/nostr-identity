{
  "name": "nostr-identity",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "services/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "pnpm --filter @nostr-identity/web dev",
    "build": "pnpm --filter ./packages/** build && pnpm --filter @nostr-identity/web build",
    "build:contract": "cd contracts/nostr-identity-contract-zkp-tee && cargo build --target wasm32-wasip2 --release",
    "build:all": "pnpm build:contract && pnpm build",
    "start": "pnpm --filter @nostr-identity/web start",
    "lint": "pnpm --filter @nostr-identity/web lint",
    "clean": "./scripts/clean.sh"
  },
  "devDependencies": {
    "@types/node": "^20",
    "typescript": "^5"
  }
}
